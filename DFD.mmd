%% Workflow-style DFD for Teacher Scheduling (top-down, centered)
flowchart TB
  %% Actors
  Admin[Admin]
  Teacher[Teacher]
  Student[Student]

  Admin -->|login| Login[Login]
  Teacher -->|login| Login
  Student -->|login| Login

  %% Linear workflow
  Login --> Dashboard[Dashboard]
  Dashboard --> ViewSchedule[View / Schedule Builder]

  subgraph System[Scheduling System]
    direction TB
    SB[Schedule Builder]
    Prefill[Prefill Overlay / Breaks]
    AssignModal[Assign Modal]
    API[API Routes]
    ScheduleBlock[ScheduleBlock record]
    DB[(Postgres / Prisma)]
  end

  ViewSchedule --> SB
  SB --> Prefill
  Prefill --> AssignModal
  AssignModal --> API
  API --> ScheduleBlock
  ScheduleBlock --> DB

  %% API provides schedules and exports
  API --> TeacherView[Teacher View]
  API --> StudentView[Student View]
  API --> Export[Export (PDF/CSV)]

  %% Admin action (dashed)
  AdminAction[Admin: POST /api/admin/schedules] -.-> API

  %% Minimal legend styling
  classDef box fill:#fff,stroke:#333,stroke-width:1px;
  class SB,Prefill,AssignModal,API,ScheduleBlock,DB,Export box;
